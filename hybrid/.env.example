HYBRID_APP_NAME=rclone-hybrid
APP_TIMEZONE=Europe/Moscow
HYBRID_RCLONE_CONFIG=/root/.config/rclone/rclone.conf
HYBRID_ENABLE_SCHEDULER=true
HYBRID_STANDARD_INTERVAL_MINUTES=1
HYBRID_HEAVY_HOUR=3
HYBRID_WATCHER_DEBOUNCE_SECONDS=45
HYBRID_COPY_STARTUP_DELAY_SECONDS=60
HYBRID_COPY_MIN_START_INTERVAL_SECONDS=60
HYBRID_DEFAULT_TIMEOUT_SECONDS=3600
HYBRID_OUTPUT_TAIL_CHARS=8000
HYBRID_DRY_RUN=false
# HYBRID_API_TOKEN=change-me
